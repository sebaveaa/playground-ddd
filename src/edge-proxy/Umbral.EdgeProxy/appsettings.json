{
  "AllowedOrigins": [
    "http://localhost:5173",
    "http://localhost:3000"
  ],
  "ReverseProxy": {
    "Routes": {
      "mission-design": {
        "ClusterId": "mission-design",
        "Match": {
          "Path": "/mission-design/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/mission-design"
          }
        ]
      },
      "session-operations": {
        "ClusterId": "session-operations",
        "Match": {
          "Path": "/session-operations/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/session-operations"
          }
        ]
      },
      "session-hub": {
        "ClusterId": "session-operations",
        "Match": {
          "Path": "/session-hub/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/session-hub"
          }
        ]
      },
      "scoring-audit": {
        "ClusterId": "scoring-audit",
        "Match": {
          "Path": "/scoring-audit/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/scoring-audit"
          }
        ]
      },
      "auth": {
        "ClusterId": "keycloak",
        "Match": {
          "Path": "/auth/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/auth"
          }
        ]
      }
    },
    "Clusters": {
      "mission-design": {
        "Destinations": {
          "primary": {
            "Address": "http://mission-design-service:8080/"
          }
        }
      },
      "session-operations": {
        "Destinations": {
          "primary": {
            "Address": "http://session-operations-service:8080/"
          }
        }
      },
      "scoring-audit": {
        "Destinations": {
          "primary": {
            "Address": "http://scoring-audit-service:8080/"
          }
        }
      },
      "keycloak": {
        "Destinations": {
          "primary": {
            "Address": "http://keycloak:8080/"
          }
        }
      }
    }
  }
}
